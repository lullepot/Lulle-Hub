    btn.Size = UDim2.new(0,220,0,40)
    btn.Position = UDim2.new(0.5,-110,0.55,0)
    btn.Text = "LOGIN"

    btn.MouseButton1Click:Connect(function()
        local u = users[user.Text]

        if u and u.password == pass.Text then
