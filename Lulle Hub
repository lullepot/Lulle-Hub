    response.TextWrapped = true

    box.FocusLost:Connect(function()
        local q = box.Text:lower()

        if q:find("oi") then
            response.Text = "Olá 👋 bem-vindo ao Lulle Hub"
        elseif q:find("esp") then
            response.Text = "Use os botões abaixo para ativar ESP."
        else
            response.Text = "Não entendi 🤖"
        end
    end)
end

--================ HUB =================
local function LoadHub()
    Clear()

    local function Toggle(name,key,y)
        local btn = Instance.new("TextButton", content)
        btn.Size = UDim2.new(0,240,0,42)
        btn.Position = UDim2.new(0,20,0,y)
        btn.TextColor3 = Color3.new(1,1,1)
        btn.Font = Enum.Font.GothamBold
        Instance.new("UICorner", btn)

        local function Update()
            if config.esp[key] then
                btn.Text = name.." ON"
                btn.BackgroundColor3 = Color3.fromRGB(140,0,255)
            else
                btn.Text = name.." OFF"
                btn.BackgroundColor3 = Color3.fromRGB(55,55,55)
            end
        end

        Update()

        btn.MouseButton1Click:Connect(function()
            config.esp[key] = not config.esp[key]
            Save()
            Update()
        end)
    end

    Toggle("ESP CLOVER","clover",20)
    Toggle("ESP CHEST","chest",75)
    Toggle("ESP EGG","egg",130)
    Toggle("ESP PLAYERS","players",185)

    if currentRole == "owner" then
        local admin = Instance.new("TextLabel", content)
        admin.Size = UDim2.new(0,250,0,40)
        admin.Position = UDim2.new(1,-270,0,20)
        admin.Text = "👑 Owner Panel Active"
        admin.TextColor3 = Color3.fromRGB(255,255,255)
        admin.BackgroundTransparency = 1
    end

    IAChat()
end

